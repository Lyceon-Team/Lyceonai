{
  "name": "rest-express",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx --env-file=.env.local server/index.ts",
    "dev:server": "cross-env NODE_ENV=development tsx --env-file=.env.local server/index.ts",
    "dev:client": "vite",
    "dev:all": "concurrently -n server,client -c blue,green \"pnpm run dev:server\" \"pnpm run dev:client\"",
    "prebuild": "rimraf dist client/dist",
    "build": "vite build && pnpm -s exec esbuild server/index.ts --bundle --platform=node --packages=external --format=esm --outfile=dist/index.js",
    "build:vercel": "pnpm -s run build && pnpm -s exec esbuild server/index.ts --bundle --platform=node --format=cjs --outfile=dist/vercel-api.cjs",
    "postbuild": "node scripts/check-no-cdn-katex.js",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "check": "tsc",
    "typecheck": "npm run check",
    "lint": "echo 'No linting configured'",
    "db:push": "drizzle-kit push",
    "test": "vitest run",
    "test:ci": "vitest run tests/ci",
    "test:integration": "vitest run tests/integration",
    "test:api": "vitest run apps/api/test",
    "test:watch": "vitest",
    "test:all": "vitest run",
    "exam:smoke": "vitest run tests/ci/full-length-exam.smoke.test.ts",
    "cleanup:stems": "tsx server/scripts/cleanup-question-stems.ts",
    "backfill:metadata": "tsx server/scripts/backfill-question-metadata.ts",
    "test:security": "vitest run tests/idor.regression.test.ts tests/entitlements.regression.test.ts",
    "route:validate": "node scripts/validate-route-registry.mjs",
    "tutor:schema:proof": "tsx scripts/tutor-schema-proof.ts",
    "tutor:schema:assert": "tsx scripts/tutor-schema-proof.ts --assert-only",
    "audit:ci": "pnpm audit --json > audit-output.json || test -s audit-output.json",
    "verify:csrf": "npx tsx scripts/verify-csrf-protection.ts"
  },
  "dependencies": {
    "@google-cloud/documentai": "^9.6.0",
