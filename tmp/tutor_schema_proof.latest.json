      },
      {
        "table_name": "tutor_question_links",
        "constraint_name": "tutor_question_links_relationship_type_check",
        "constraint_def": "CHECK ((relationship_type = ANY (ARRAY['current'::text, 'similar_retry'::text, 'simpler_variant'::text, 'harder_variant'::text, 'concept_extension'::text])))"
      }
    ],
    "tutor_memory_summaries": [
      {
        "table_name": "tutor_memory_summaries",
