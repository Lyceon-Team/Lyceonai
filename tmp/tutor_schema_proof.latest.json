  "checks": {
    "tutor_conversations": [
      {
        "table_name": "tutor_conversations",
        "constraint_name": "tutor_conversations_assignment_mode_check",
        "constraint_def": "CHECK ((assignment_mode = ANY (ARRAY['deterministic'::text, 'explore'::text, 'manual_override'::text])))"
      },
      {
        "table_name": "tutor_conversations",
        "constraint_name": "tutor_conversations_entry_mode_check",
        "constraint_def": "CHECK ((entry_mode = ANY (ARRAY['scoped_question'::text, 'scoped_session'::text, 'general'::text])))"
      },
      {
        "table_name": "tutor_conversations",
        "constraint_name": "tutor_conversations_source_surface_check",
