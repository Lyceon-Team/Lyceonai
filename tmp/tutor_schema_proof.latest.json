      }
    ],
    "tutor_messages": [
      {
        "table_name": "tutor_messages",
        "constraint_name": "chk_tutor_messages_client_turn_id_student_only",
        "constraint_def": "CHECK ((((role = 'student'::text) AND (client_turn_id IS NOT NULL)) OR (role = ANY (ARRAY['tutor'::text, 'system'::text]))))"
      },
      {
        "table_name": "tutor_messages",
        "constraint_name": "tutor_messages_content_kind_check",
        "constraint_def": "CHECK ((content_kind = ANY (ARRAY['message'::text, 'suggestion'::text, 'consent_prompt'::text, 'system_note'::text])))"
      },
      {
        "table_name": "tutor_messages",
        "constraint_name": "tutor_messages_explanation_level_check",
        "constraint_def": "CHECK (((explanation_level >= 1) AND (explanation_level <= 5)))"
      },
      {
        "table_name": "tutor_messages",
        "constraint_name": "tutor_messages_role_check",
        "constraint_def": "CHECK ((role = ANY (ARRAY['student'::text, 'tutor'::text, 'system'::text])))"
      }
    ],
    "tutor_instruction_assignments": [
      {
        "table_name": "tutor_instruction_assignments",
        "constraint_name": "tutor_instruction_assignments_assignment_mode_check",
        "constraint_def": "CHECK ((assignment_mode = ANY (ARRAY['deterministic'::text, 'explore'::text, 'manual_override'::text])))"
      }
    ],
    "tutor_question_links": [
      {
        "table_name": "tutor_question_links",
        "constraint_name": "chk_tutor_question_links_not_same_canonical",
        "constraint_def": "CHECK ((source_question_canonical_id <> related_question_canonical_id))"
      },
      {
        "table_name": "tutor_question_links",
        "constraint_name": "tutor_question_links_difficulty_delta_check",
