{
  "name": "@sat-copilot/api",
  "version": "1.0.0",
  "type": "module",
  "main": "./src/index.js",
  "scripts": {
    "dev": "NODE_ENV=development tsx src/index.ts",
    "build": "pnpm exec esbuild ./src/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "start": "NODE_ENV=production node dist/index.js",
    "next:dev": "next dev --port 3001",
    "next:build": "next build",
    "next:start": "next start --port 3001",
    "seed:dev-question": "tsx scripts/seed-dev-question.ts"
  },
  "dependencies": {
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "esbuild": "^0.25.12",
    "tsx": "^4.19.1"
  }
}
