# Supabase Auth Configuration
SUPABASE_URL=your-supabase-url
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OAuth Providers
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Optional: Apple Sign-In (future)
# APPLE_CLIENT_ID=
# APPLE_TEAM_ID=
# APPLE_KEY_ID=
# APPLE_PRIVATE_KEY=

# Application Configuration
ENABLE_UNDER_13_GATE=true
BASE_URL=https://lyceon.ai

# Database
DATABASE_URL=your-postgres-connection-string

# OpenAI (for embeddings)
OPENAI_API_KEY=your-openai-key

# Frontend calculator integration (browser-visible)
VITE_DESMOS_API_KEY=your-desmos-api-key

# Emails
RESEND_API_KEY=lyceon-resend-api-key

# Payments and Guardian Age Verification
STRIPE_SECRET_KEY=lyceon-stripe-secret-key

# link to localhost url for local development
PUBLIC_SITE_URL=http://localhost:5173

# CSRF (double-submit cookie)
CSRF_SECRET=your-csrf-secret

# Default Port
PORT=5000
