	},
	"variable": [
		{ "key": "baseUrl", "value": "http://localhost:5000", "type": "string" },
		{ "key": "siteUrl", "value": "http://localhost:5173", "type": "string" },
		{ "key": "testEmail", "value": "test@example.com", "type": "string" },
		{ "key": "testPassword", "value": "TestPassword123!", "type": "string" },
		{ "key": "adminEmail", "value": "admin@example.com", "type": "string" },
		{ "key": "adminPassword", "value": "AdminPassword123!", "type": "string" },
		{ "key": "adminPasscode", "value": "", "type": "string" },
		{ "key": "guardianEmail", "value": "guardian@example.com", "type": "string" },
		{ "key": "guardianPassword", "value": "GuardianPass123!", "type": "string" },
		{ "key": "questionId", "value": "REPLACE_ME", "type": "string" },
		{ "key": "studentId", "value": "REPLACE_ME", "type": "string" },
		{ "key": "sessionId", "value": "REPLACE_ME", "type": "string" },
		{ "key": "reviewSessionId", "value": "REPLACE_ME", "type": "string" },
		{ "key": "notificationId", "value": "REPLACE_ME", "type": "string" },
		{ "key": "studentLinkCode", "value": "REPLACE_ME", "type": "string" },
		{ "key": "fullLengthSessionId", "value": "REPLACE_ME", "type": "string" }
	],
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Set Origin header for CSRF protection (must match allowed origins)",
					"pm.request.headers.upsert({ key: 'Origin', value: pm.collectionVariables.get('siteUrl') });"
				]
			}
		}
	],
	"item": [
		{
			"name": "🔐 Authentication",
			"item": [
				{
					"name": "Sign Up",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\",\n  \"role\": \"student\"\n}"
						},
						"url": { "raw": "{{baseUrl}}/api/auth/signup", "host": ["{{baseUrl}}"], "path": ["api","auth","signup"] }
					}
				},
				{
					"name": "Sign In (Student)",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Sign in successful', function () {",
									"    pm.response.to.have.status(200);",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
